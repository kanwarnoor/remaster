generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgres"
}

enum Visibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique()
  password  String    
  premium   Boolean?  @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  username  String    @unique 
  albums Album[]
  tracks Track[]
  playlists Playlist[]
  invite Invite? @relation("InviteClaimedBy")
}

model Album {
  id           String   @id @default(uuid())
  name        String
  artist      String
  description String?
  image       String?
  tracks      AlbumTracks[]
  user        User    @relation(fields: [userId], references: [id])
  userId      String
  visibility  Visibility @default(PRIVATE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Playlist {
  id String @id @default(uuid())
  name String
  description String?
  tracks PlaylistTracks[]
  user User @relation(fields: [userId], references: [id])
  userId String
  visibility Visibility @default(PRIVATE)
  image String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  default Boolean @default(false)
}

model Track {
  id         String   @id @default(uuid())
  artist     String?
  audio      String
  duration   Float?
  image      String?
  name       String?
  size       Int?
  optimized  Boolean? @default(false)
  user       User @relation(fields: [userId], references: [id])
  userId     String
  albums     AlbumTracks[]
  playlists PlaylistTracks[]
  visibility Visibility @default(PRIVATE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AlbumTracks {
  album Album @relation(fields: [albumId], references: [id])
  albumId String
  track Track @relation(fields: [trackId], references: [id])
  trackId String
  sort String @default("a0")
  @@id([albumId, trackId])
}

model PlaylistTracks {
  id         String   @id @default(uuid())
  playlist   Playlist @relation(fields: [playlistId], references: [id])
  playlistId String
  track      Track    @relation(fields: [trackId], references: [id])
  trackId    String
  sort       String   @default("a0")
  @@index([playlistId])
  @@index([trackId])
}

model Invite{
  id String @id @default(uuid())
  code String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  claimed Boolean @default(false)
  userId  String? @unique
  user User? @relation("InviteClaimedBy" , fields: [userId], references: [id])
}